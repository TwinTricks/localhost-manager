{
  "manifest_version": 3,
  "name": "Localhost Manager",
  "version": "1.1.0",
  "description": "Bookmark localhost dev servers by project name, not by port. Live status, quick switching, import/export.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "http://[::1]/*",
    "https://[::1]/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Localhost Manager"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+L", "mac": "Command+Shift+L" }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/ui/*.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
